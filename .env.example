# Vercel — gestion-manager
# Copier dans Vercel → Settings → Environment Variables (Production + Preview)
# ou : vercel env pull .env.local

# ── Envoi test campagnes ───────────────────────────────────────────────────────
CAMPAIGN_TEST_EMAIL=giffareno237@gmail.com
NEXT_PUBLIC_CAMPAIGN_TEST_EMAIL=giffareno237@gmail.com
# CAMPAIGN_TEST_PHONE=237693646080

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://gestion-manager.vercel.app
NEXT_PUBLIC_BOXING_CENTER_SITE=https://boxingcenter.fr/
# Images email : logo integre (cid). Hero leger via gestion-manager (pas boxingcenter.fr).
# NEXT_PUBLIC_EMAIL_HERO_URL=https://gestion-manager.vercel.app/offre-d-ete/assets/email-shirt.jpg

# ── Bot Bothosting (comme NYC Cookies) ────────────────────────────────────────
# URL affichée au démarrage du bot sur Bothosting
NEXT_PUBLIC_WHATSAPP_BOT_URL=http://us2.bot-hosting.net:20042

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://ulxtbvxdueolvnjhpzvw.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Sécurité — même SITE_API_SECRET que le bot Bothosting ─────────────────────
SITE_API_SECRET=
SESSION_SECRET=

# ── Super administrateur (env uniquement) ─────────────────────────────────────
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# ── Email — fournisseur (mailjet | brevo | auto) ──────────────────────────────
# auto = Mailjet si au moins un compte est configuré, sinon Brevo
EMAIL_PROVIDER=mailjet

# ── Mailjet — 3 comptes (~8000 emails / vague / compte) ───────────────────────
# Chaque compte = abonnement Mailjet séparé. API : Account Settings → REST API
# Valider boxing-center-portet.fr + no-reply@boxing-center-portet.fr sur chaque compte.
MAILJET_1_API_KEY=
MAILJET_1_SECRET_KEY=
MAILJET_1_SENDER_EMAIL=no-reply@boxing-center-portet.fr
MAILJET_1_SENDER_NAME=Boxing Center
MAILJET_1_LABEL=Campagne 1 — no-reply

MAILJET_2_API_KEY=
MAILJET_2_SECRET_KEY=
MAILJET_2_SENDER_EMAIL=no-reply@boxing-center-portet.fr
MAILJET_2_SENDER_NAME=Boxing Center
MAILJET_2_LABEL=Campagne 2 — no-reply

MAILJET_3_API_KEY=
MAILJET_3_SECRET_KEY=
MAILJET_3_SENDER_EMAIL=no-reply@boxing-center-portet.fr
MAILJET_3_SENDER_NAME=Boxing Center
MAILJET_3_LABEL=Campagne 3 — no-reply

MAILJET_WAVE_LIMIT=8000
MAILJET_REPLY_TO=boxingcenter31@gmail.com
# Routage automatique par type d'email (numéro de compte 1, 2 ou 3)
MAILJET_PURPOSE_CAMPAIGN=1
MAILJET_PURPOSE_NOTIFY=1
MAILJET_PURPOSE_CREDENTIALS=2

# ── Brevo — repli si EMAIL_PROVIDER=brevo ou auto sans Mailjet ─────────────────
# Clé v3 : xkeysib-… — Brevo → SMTP & API → Clés API
BREVO_API_KEY=
BREVO_SMTP_LOGIN=
BREVO_SMTP_KEY=
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SENDER_EMAIL=suzinabot@11426075.brevosend.com
BREVO_SENDER_NAME=Boxing Center
BREVO_REPLY_TO=boxingcenter31@gmail.com

# Adresse légale affichée en pied d'email (obligatoire campagnes FR)
NEXT_PUBLIC_LEGAL_ADDRESS=Boxing Center — clubs de boxe à Toulouse et agglomération, France

# ── Emails (affichage) ────────────────────────────────────────────────────────
NEXT_PUBLIC_BREVO_SENDER_EMAIL=suzinabot@11426075.brevosend.com
NEXT_PUBLIC_CONTACT_EMAIL=boxingcenter31@gmail.com
NEXT_PUBLIC_RECEPTION_EMAIL=boxingcenter31@gmail.com

# ── Offre Été 2026 ───────────────────────────────────────────────────────────
# Landing hébergée sur boxingcenter.fr (pas sur gestion-manager)
NEXT_PUBLIC_OFFRE_ETE_LANDING_URL=https://boxingcenter.fr/offre-d-ete
# Origines autorisées pour le tracking des vues (CORS)
OFFRE_ETE_CORS_ORIGINS=https://boxingcenter.fr,https://www.boxingcenter.fr
# false pour masquer le bouton « Réinitialiser » dans /admin/offre-ete
OFFRE_ETE_ALLOW_RESET=true

# ── Chatbot Portet ────────────────────────────────────────────────────────────
CHATBOT_ALLOW_RESET=true
# CHATBOT_CORS_ORIGINS=https://portet.boxingcenter.fr
# CHATBOT_NOTIFY_EMAIL=boxingcenter31@gmail.com
# OFFRE_ETE_TSHIRT_NOTIFY_EMAIL=boxingcenter31@gmail.com
