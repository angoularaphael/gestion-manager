{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/offre-d-ete/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "functions": {
    "app/api/bot/route.js": {
      "maxDuration": 120
    },
    "app/api/clients/import/route.js": {
      "maxDuration": 120
    },
    "app/api/managers/send-email/route.js": {
      "maxDuration": 60
    },
    "app/api/promoteurs/send-email/route.js": {
      "maxDuration": 60
    },
    "app/api/boxeurs/send-email/route.js": {
      "maxDuration": 60
    },
    "app/api/clients/send-email/route.js": {
      "maxDuration": 60
    },
    "app/api/admin/whatsapp/route.js": {
      "maxDuration": 30
    },
    "app/api/bot/summary/route.js": {
      "maxDuration": 30
    }
  }
}
